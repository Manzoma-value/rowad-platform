generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Maqsad {
  DEEN // الدين
  AQL // العقل
  NAFS // النفس
  NASL // النسل
  MAL // المال
}

// ─── النموذج التعليمي للرواد (Rowad Educational Model) ───

enum TeacherOnboardingStatus {
  PENDING_APPLICATION // signed up, must fill the application
  UNDER_REVIEW // application submitted, awaiting admin review
  ACTIVE // application approved
  REJECTED // application rejected (terminal)
}

// ─── Teacher Application (replaces the Rowad stage onboarding) ───

enum Gender {
  MALE
  FEMALE
}

enum TeacherCurrentRole {
  TEACHER
  SUPERVISOR
  PRINCIPAL
  VICE_PRINCIPAL
  COUNSELOR
  TRAINER
  TEAM_LEAD
  RESEARCHER
  VOLUNTEER
  OTHER
}

enum QualificationLevel {
  DIPLOMA
  BACHELOR
  HIGHER_DIPLOMA
  MASTER
  PHD
}

enum ExperienceRange {
  LT_3
  Y_3_5
  Y_6_10
  Y_11_15
  GT_15
}

enum AchievementScope {
  INSTITUTIONAL
  CITY
  COUNTRY
  REGIONAL
  INTERNATIONAL
}

model TeacherApplication {
  id         String @id @default(uuid()) @db.Uuid
  teacher_id String @unique @db.Uuid
  school_id  String @db.Uuid

  // Personal
  full_name String
  age       Int
  country   String
  city      String
  phone     String
  email     String
  gender    Gender

  // Nomination
  nominating_entity String?
  nominator_name    String?
  nominator_role    String?

  // Current role
  current_role       TeacherCurrentRole
  current_role_other String?

  // Qualification
  qualification          QualificationLevel
  specialization         String
  graduation_institution String

  // Experience
  experience_areas       String[]
  experience_areas_other String?
  years_of_experience    ExperienceRange

  // Categories worked with
  target_groups       String[]
  target_groups_other String?

  // Contributions
  contributions String[]

  // Achievements
  has_achievements   Boolean           @default(false)
  achievements_scope AchievementScope?

  // Languages — JSON array: [{lang:"ar"|"en"|..., level:"BEGINNER"|...}, ...]
  languages       Json    @default("[]")
  languages_other String?

  // Optional attachments (the user just declares what they will bring)
  attachments String[]
  notes       String?

  // Review tracking
  submitted_at   DateTime  @default(now())
  reviewer_id    String?   @db.Uuid
  reviewer_notes String?
  reviewed_at    DateTime?

  teacher  Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  school   School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  reviewer Profile? @relation("TeacherAppReviewedBy", fields: [reviewer_id], references: [id])

  @@index([school_id, submitted_at(sort: Desc)])
  @@map("teacher_applications")
}

enum RowadStage {
  STAGE1
  STAGE2
}

// ─── Owner Reports — formal institutional reports the platform owner
//     authors and assigns to a specific school. School admins of that
//     school can view (read-only). DRAFT → PUBLISHED. ───
enum OwnerReportStatus {
  DRAFT
  PUBLISHED
}

model OwnerReport {
  id           String            @id @default(uuid()) @db.Uuid
  school_id    String            @db.Uuid
  created_by   String            @db.Uuid
  title        String
  subtitle     String?
  description  String?
  report_date  DateTime?
  introduction String?
  closing_note String?
  status       OwnerReportStatus @default(DRAFT)
  // Ordered content blocks: [{ id, type: "TEXT"|"HEADING"|"HIGHLIGHT"|"BULLET_LIST", title?, body?, items?: string[] }]
  blocks       Json              @default("[]")
  // Image gallery: [{ url, path, caption? }]
  images       Json              @default("[]")
  // Downloadable files: [{ url, path, name, size?, mime? }]
  attachments  Json              @default("[]")
  // External links: [{ title, description?, url }]
  links        Json              @default("[]")
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  published_at DateTime?

  school School  @relation(fields: [school_id], references: [id], onDelete: Cascade)
  author Profile @relation("OwnerReportAuthor", fields: [created_by], references: [id])

  @@index([school_id, status, published_at(sort: Desc)])
  @@index([status, updated_at(sort: Desc)])
  @@map("owner_reports")
}

// Per-session score for the card games. Game mode only — no admin
// approval, no gating. Owner sees per-user history; teacher/student
// also see their own best score in localStorage.
model RowadGameSubmission {
  id         String     @id @default(uuid()) @db.Uuid
  school_id  String     @db.Uuid
  profile_id String     @db.Uuid
  stage      RowadStage
  score      Int
  total      Int        @default(25)
  created_at DateTime   @default(now())

  school  School  @relation(fields: [school_id], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@index([school_id, created_at(sort: Desc)])
  @@index([profile_id, stage, score(sort: Desc)])
  @@map("rowad_game_submissions")
}

// One model per school — an editable copy of the 5×5 educational model.
// Used by the card-game (STAGE1 / STAGE2) — read-only for players.
model RowadModel {
  id         String   @id @default(uuid()) @db.Uuid
  school_id  String   @unique @db.Uuid
  title_ar   String   @default("النموذج التعليمي للرواد")
  title_sq   String?
  created_at DateTime @default(now())

  school   School         @relation(fields: [school_id], references: [id], onDelete: Cascade)
  levels   RowadLevel[]
  concepts RowadConcept[]

  @@map("rowad_models")
}

// The 5 rows (المستويات) — editable bilingual labels
model RowadLevel {
  id       String  @id @default(uuid()) @db.Uuid
  model_id String  @db.Uuid
  order    Int // 1..5
  name_ar  String
  name_sq  String?

  model RowadModel @relation(fields: [model_id], references: [id], onDelete: Cascade)

  @@unique([model_id, order])
  @@map("rowad_levels")
}

// The 25 concepts. Answer key = (maqsad = correct column) + (level = correct row)
model RowadConcept {
  id       String @id @default(uuid()) @db.Uuid
  model_id String @db.Uuid
  maqsad   Maqsad // correct column
  level    Int // correct row 1..5
  order    Int // order within the level

  // Stage 1 card / concept name
  name_ar String
  name_sq String?
  // المفهوم الاستراتيجي
  strategic_ar String?
  strategic_sq String?
  // الوصف
  description_ar String?
  description_sq String?
  // الواجب
  duty_ar String?
  duty_sq String?
  // الأجر
  reward_ar String?
  reward_sq String?
  // الثمرة
  fruit_ar String?
  fruit_sq String?
  // مؤشر التحقق
  verification_ar String?
  verification_sq String?

  created_at DateTime @default(now())

  model RowadModel @relation(fields: [model_id], references: [id], onDelete: Cascade)

  @@map("rowad_concepts")
}

model Invite {
  id    String     @id @default(uuid()) @db.Uuid
  token String     @unique
  type  InviteType

  school_id  String  @db.Uuid
  created_by String  @db.Uuid
  used_by    String? @db.Uuid

  is_active  Boolean   @default(true)
  use_count  Int       @default(0)
  max_uses   Int?
  expires_at DateTime?
  used_at    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  school  School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  creator Profile  @relation("InvitesCreatedBy", fields: [created_by], references: [id], onDelete: Restrict)
  usedBy  Profile? @relation("InviteUsedBy", fields: [used_by], references: [id], onDelete: SetNull)

  @@map("invites")
}

enum InviteType {
  TEACHER
  STUDENT
  ADMIN
}

// One trait per Maqsad per stage (so max 5 traits per stage)
model StageTrait {
  id         String   @id @default(uuid()) @db.Uuid
  stage_id   String   @db.Uuid
  maqsad     Maqsad
  name       String // e.g. "الدراية"
  definition String // e.g. "قدرة الطالب على فهم سبب الفعل..."
  created_at DateTime @default(now())

  stage              RoadmapStage      @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  elements           TraitElement[]
  module_main_traits RoadmapModule[]   @relation("ModuleMainTrait")
  evaluations        TraitEvaluation[]

  @@unique([stage_id, maqsad]) // one trait per Maqsad per stage
  @@map("stage_traits")
}

// Assessment elements — visual guidance only, not scored individually
model TraitElement {
  id         String   @id @default(uuid()) @db.Uuid
  trait_id   String   @db.Uuid
  text       String // e.g. "يفهم الطالب لماذا يتحرك"
  order      Int
  created_at DateTime @default(now())

  trait StageTrait @relation(fields: [trait_id], references: [id], onDelete: Cascade)

  @@map("trait_elements")
}

// Link the main activating trait to a module
// Add this field to RoadmapModule:
// main_trait_id  String?  @db.Uuid
// main_trait     StageTrait? @relation("ModuleMainTrait", fields: [main_trait_id], references: [id])

// Teacher's trait evaluation after student completes a module
model TraitAssessment {
  id           String   @id @default(uuid()) @db.Uuid
  module_id    String   @db.Uuid
  student_id   String   @db.Uuid
  teacher_id   String   @db.Uuid
  general_note String?
  submitted_at DateTime @default(now())
  updated_at   DateTime @updatedAt

  module       RoadmapModule     @relation(fields: [module_id], references: [id], onDelete: Cascade)
  student      Student           @relation(fields: [student_id], references: [id], onDelete: Cascade)
  teacher      Teacher           @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  trait_scores TraitEvaluation[]

  @@unique([module_id, student_id]) // one assessment per student per module, but updatable
  @@map("trait_assessments")
}

// One score row per trait inside the assessment
model TraitEvaluation {
  id            String   @id @default(uuid()) @db.Uuid
  assessment_id String   @db.Uuid
  trait_id      String   @db.Uuid
  score         Float // e.g. 42.0 out of 50 for main, or 8.0 out of 12.5 for others
  note          String?
  created_at    DateTime @default(now())

  assessment TraitAssessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  trait      StageTrait      @relation(fields: [trait_id], references: [id], onDelete: Cascade)

  @@unique([assessment_id, trait_id]) // one score per trait per assessment
  @@map("trait_evaluations")
}

model Profile {
  id                           String              @id @db.Uuid
  created_at                   DateTime            @default(now())
  full_name                    String
  email                        String?             @unique
  is_active                    Boolean             @default(true)
  // True for read-only demo accounts (e.g. an investor account on the admin
  // role). The auth helpers refuse to authorise any write endpoint when this
  // is set; UI hides mutating buttons.
  is_view_only                 Boolean             @default(false)
  role                         Role
  reviewed_assessment_attempts AssessmentAttempt[] @relation("AssessmentReviewedBy")
  school_admin_memberships     SchoolAdminMember[]
  student                      Student?
  teacher                      Teacher?
  posts                        Post[]
  post_reactions               PostReaction[]
  reviewedTeacherApplications  TeacherApplication[] @relation("TeacherAppReviewedBy")
  reviewedLessons              Lesson[]             @relation("LessonReviewedBy")
  reviewedQuizzes              Quiz[]               @relation("QuizReviewedBy")
  rowadGameSubmissions         RowadGameSubmission[]
  authoredOwnerReports         OwnerReport[]        @relation("OwnerReportAuthor")
  authoredTeacherGroups        TeacherGroup[]       @relation("TeacherGroupAuthor")
  avatar_url                   String?
  avatar_path                  String?
  created_invites              Invite[]            @relation("InvitesCreatedBy")
  used_invites                 Invite[]            @relation("InviteUsedBy")

  @@map("profiles")
}

model School {
  id                 String              @id @default(uuid()) @db.Uuid
  /// Primary Arabic name (always required). Used as the canonical identifier.
  name               String              @unique
  /// Optional Latin-script name shown when the UI language is Albanian/English.
  /// Falls back to `name` if null.
  name_alt           String?
  created_at         DateTime            @default(now())
  language           String              @default("ar")
  description        String?
  slug               String              @unique @default("")
  color_bg           String              @default("#0B0B0C")
  color_primary      String              @default("#ac8e52")
  color_secondary    String              @default("#E5B93C")
  /// Whether this school is active. When false the owner has deactivated it:
  /// the subdomain landing shows a "deactivated" page and users cannot log in.
  is_active          Boolean             @default(true)
  /// Per-school feature toggles, e.g. { "hub": false, "lessons": true }.
  /// Empty object = all features on (see src/lib/features.ts for the resolver).
  /// JSON (not boolean columns) so new features ship without a migration.
  features           Json                @default("{}")
  announcements      Announcement[]
  assessmentAttempts AssessmentAttempt[]
  assessments        Assessment[]
  classes            Class[]
  quizzes            Quiz[]
  lessons            Lesson[]
  roadmap            Roadmap?
  rowad_model        RowadModel?
  admins             SchoolAdminMember[]
  students           Student[]
  teachers           Teacher[]
  teacher_applications TeacherApplication[]
  posts              Post[]
  invites            Invite[]
  rowadGameSubmissions RowadGameSubmission[]
  owner_reports      OwnerReport[]
  teacher_groups     TeacherGroup[]

  @@map("schools")
}

/// Join table: a school can have many admins, an admin can manage many schools.
model SchoolAdminMember {
  id         String   @id @default(uuid()) @db.Uuid
  school_id  String   @db.Uuid
  profile_id String   @db.Uuid
  created_at DateTime @default(now())
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  profile    Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([school_id, profile_id])
  @@map("school_admins")
}

model Teacher {
  id                String                  @id @default(uuid()) @db.Uuid
  created_at        DateTime                @default(now())
  profile_id        String                  @unique @db.Uuid
  school_id         String                  @db.Uuid
  onboarding_status TeacherOnboardingStatus @default(PENDING_APPLICATION)
  announcements     Announcement[]
  classes           Class[]
  quizzes           Quiz[]
  lessons           Lesson[]
  profile           Profile                 @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  school            School                  @relation(fields: [school_id], references: [id], onDelete: Cascade)
  traitAssessments  TraitAssessment[]
  application       TeacherApplication?
  group_memberships TeacherGroupMember[]

  @@index([school_id])
  @@map("teachers")
}

// ─── Teacher Groups — private teacher communities organized by admin.
//     A teacher can belong to many groups; a group has many teachers. ───
model TeacherGroup {
  id          String   @id @default(uuid()) @db.Uuid
  school_id   String   @db.Uuid
  name        String
  description String?
  created_by  String   @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  school  School               @relation(fields: [school_id], references: [id], onDelete: Cascade)
  author  Profile              @relation("TeacherGroupAuthor", fields: [created_by], references: [id])
  members TeacherGroupMember[]

  @@index([school_id, updated_at(sort: Desc)])
  @@map("teacher_groups")
}

model TeacherGroupMember {
  group_id   String   @db.Uuid
  teacher_id String   @db.Uuid
  joined_at  DateTime @default(now())

  group   TeacherGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  teacher Teacher      @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@id([group_id, teacher_id])
  @@index([teacher_id])
  @@map("teacher_group_members")
}

model Student {
  id                  String                  @id @default(uuid()) @db.Uuid
  class_id            String?                 @db.Uuid
  created_at          DateTime                @default(now())
  onboarding_status   StudentOnboardingStatus @default(PENDING_INTAKE)
  profile_id          String                  @unique @db.Uuid
  school_id           String?                 @db.Uuid
  city                String?
  age                 Int?
  assessment_attempts AssessmentAttempt[]
  moduleAttempts      ModuleAttempt[]
  quiz_attempts       QuizAttempt[]
  lesson_attempts     LessonAttempt[]
  class               Class?                  @relation(fields: [class_id], references: [id])
  profile             Profile                 @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  school              School?                 @relation(fields: [school_id], references: [id])
  traitAssessments    TraitAssessment[]

  @@index([school_id])
  @@index([class_id])
  @@index([school_id, onboarding_status])
  @@map("students")
}

model Class {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  created_at         DateTime            @default(now())
  school_id          String              @db.Uuid
  teacher_id         String?             @db.Uuid
  announcements      Announcement[]
  assessmentAttempts AssessmentAttempt[]
  school             School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  teacher            Teacher?            @relation(fields: [teacher_id], references: [id])
  quizzes            Quiz[]
  lessons            Lesson[]
  students           Student[]

  @@unique([school_id, name])
  @@index([teacher_id])
  @@map("classes")
}

model Announcement {
  id         String   @id @default(uuid()) @db.Uuid
  content    String
  school_id  String   @db.Uuid
  class_id   String   @db.Uuid
  teacher_id String   @db.Uuid
  created_at DateTime @default(now())
  class      Class    @relation(fields: [class_id], references: [id], onDelete: Cascade)
  school     School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  teacher    Teacher  @relation(fields: [teacher_id], references: [id], onDelete: Cascade)

  @@index([class_id, created_at])
  @@index([teacher_id])
  @@map("announcements")
}

// ─── Content review status (lessons + quizzes) ───
// DRAFT → teacher is editing.
// PENDING_REVIEW → teacher submitted, admin must approve.
// APPROVED → visible to students.
// REJECTED → goes back to DRAFT-like (editable) with reviewer_notes; teacher
//            can resubmit (transitions to PENDING_REVIEW again).
enum ContentReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model Quiz {
  id         String         @id @default(uuid()) @db.Uuid
  name       String
  school_id  String         @db.Uuid
  class_id   String         @db.Uuid
  teacher_id String         @db.Uuid
  // Concept (RoadmapModule) the quiz is tied to. Required for NEW quizzes —
  // existing ones backfilled to NULL + is_legacy=true.
  module_id  String?        @db.Uuid
  // Review pipeline
  review_status  ContentReviewStatus @default(DRAFT)
  reviewer_id    String?             @db.Uuid
  reviewer_notes String?
  submitted_at   DateTime?
  reviewed_at    DateTime?
  // Pre-milestone quizzes (no concept link). Hidden from students; visible to
  // teacher as read-only "Legacy" entries that can be cloned into a concept.
  is_legacy  Boolean        @default(false)
  created_at DateTime       @default(now())
  attempts   QuizAttempt[]
  questions  QuizQuestion[]
  class      Class          @relation(fields: [class_id], references: [id], onDelete: Cascade)
  school     School         @relation(fields: [school_id], references: [id], onDelete: Cascade)
  teacher    Teacher        @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  module     RoadmapModule? @relation("ModuleQuizzes", fields: [module_id], references: [id], onDelete: SetNull)
  reviewer   Profile?       @relation("QuizReviewedBy", fields: [reviewer_id], references: [id])
  linked_from_lessons Lesson[]

  @@index([teacher_id, created_at])
  @@index([class_id])
  @@index([module_id, review_status])
  @@index([school_id, review_status])
  @@map("quizzes")
}

model QuizQuestion {
  id             String       @id @default(uuid()) @db.Uuid
  quiz_id        String       @db.Uuid
  type           QuestionType
  text           String
  correct_answer String?
  order          Int
  created_at     DateTime     @default(now())
  answers        QuizAnswer[]
  options        QuizOption[]
  quiz           Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizOption {
  id          String       @id @default(uuid()) @db.Uuid
  question_id String       @db.Uuid
  text        String
  order       Int
  created_at  DateTime     @default(now())
  question    QuizQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("quiz_options")
}

model QuizAttempt {
  id           String       @id @default(uuid()) @db.Uuid
  quiz_id      String       @db.Uuid
  student_id   String       @db.Uuid
  score        Int?
  total        Int?
  submitted_at DateTime     @default(now())
  answers      QuizAnswer[]
  quiz         Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([quiz_id, student_id])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id          String       @id @default(uuid()) @db.Uuid
  attempt_id  String       @db.Uuid
  question_id String       @db.Uuid
  answer      String
  is_correct  Boolean?
  created_at  DateTime     @default(now())
  attempt     QuizAttempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question    QuizQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

model Assessment {
  id         String               @id @default(uuid()) @db.Uuid
  title      String
  type       AssessmentType
  school_id  String?              @db.Uuid
  is_active  Boolean              @default(true)
  created_at DateTime             @default(now())
  attempts   AssessmentAttempt[]
  questions  AssessmentQuestion[]
  school     School?              @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@map("assessments")
}

model AssessmentQuestion {
  id             String             @id @default(uuid()) @db.Uuid
  assessment_id  String             @db.Uuid
  type           QuestionType
  text           String
  correct_answer String?
  order          Int
  created_at     DateTime           @default(now())
  answers        AssessmentAnswer[]
  options        AssessmentOption[]
  assessment     Assessment         @relation(fields: [assessment_id], references: [id], onDelete: Cascade)

  @@map("assessment_questions")
}

model AssessmentOption {
  id          String             @id @default(uuid()) @db.Uuid
  question_id String             @db.Uuid
  text        String
  order       Int
  created_at  DateTime           @default(now())
  question    AssessmentQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("assessment_options")
}

model AssessmentAttempt {
  id                 String                 @id @default(uuid()) @db.Uuid
  assessment_id      String                 @db.Uuid
  student_id         String                 @db.Uuid
  score              Int?
  total              Int?
  review_status      AssessmentReviewStatus @default(PENDING)
  reviewer_id        String?                @db.Uuid
  reviewer_notes     String?
  assigned_school_id String?                @db.Uuid
  assigned_class_id  String?                @db.Uuid
  submitted_at       DateTime               @default(now())
  reviewed_at        DateTime?
  answers            AssessmentAnswer[]
  assessment         Assessment             @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  assigned_class     Class?                 @relation(fields: [assigned_class_id], references: [id])
  assigned_school    School?                @relation(fields: [assigned_school_id], references: [id])
  reviewer           Profile?               @relation("AssessmentReviewedBy", fields: [reviewer_id], references: [id])
  student            Student                @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@map("assessment_attempts")
}

model AssessmentAnswer {
  id          String             @id @default(uuid()) @db.Uuid
  attempt_id  String             @db.Uuid
  question_id String             @db.Uuid
  answer      String
  is_correct  Boolean?
  created_at  DateTime           @default(now())
  attempt     AssessmentAttempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question    AssessmentQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("assessment_answers")
}

model Roadmap {
  id         String         @id @default(uuid()) @db.Uuid
  school_id  String         @unique @db.Uuid
  title      String         @default("بنك الأسئلة")
  created_at DateTime       @default(now())
  stages     RoadmapStage[]
  school     School         @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@map("roadmaps")
}

model RoadmapStage {
  id         String          @id @default(uuid()) @db.Uuid
  roadmap_id String          @db.Uuid
  title      String
  order      Int
  created_at DateTime        @default(now())
  modules    RoadmapModule[]
  roadmap    Roadmap         @relation(fields: [roadmap_id], references: [id], onDelete: Cascade)
  traits     StageTrait[]

  @@map("roadmap_stages")
}

model RoadmapModule {
  id               String            @id @default(uuid()) @db.Uuid
  stage_id         String            @db.Uuid
  title            String
  description      String?
  order            Int
  created_at       DateTime          @default(now())
  stage            RoadmapStage      @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  contents         ModuleContent[]
  questions        RoadmapQuestion[]
  attempts         ModuleAttempt[]
  main_trait_id    String?           @db.Uuid
  main_trait       StageTrait?       @relation("ModuleMainTrait", fields: [main_trait_id], references: [id])
  traitAssessments TraitAssessment[]
  // Teacher-authored content tied to this concept
  lessons          Lesson[]          @relation("ModuleLessons")
  quizzes          Quiz[]            @relation("ModuleQuizzes")

  @@map("roadmap_modules")
}

model ModuleContent {
  id           String        @id @default(uuid()) @db.Uuid
  module_id    String        @db.Uuid
  type         ContentType
  order        Int
  body         String?
  storage_path String?
  image_url    String?
  alt_text     String?
  video_url    String?
  video_title  String?
  created_at   DateTime      @default(now())
  module       RoadmapModule @relation(fields: [module_id], references: [id], onDelete: Cascade)

  @@map("module_contents")
}

model RoadmapQuestion {
  id             String                  @id @default(uuid()) @db.Uuid
  module_id      String                  @db.Uuid
  type           QuestionType
  text           String
  correct_answer String?
  order          Int
  created_at     DateTime                @default(now())
  module         RoadmapModule           @relation(fields: [module_id], references: [id], onDelete: Cascade)
  options        RoadmapQuestionOption[]
  matching_pairs MatchingPair[]
  answers        ModuleAnswer[]

  @@map("roadmap_questions")
}

model RoadmapQuestionOption {
  id          String          @id @default(uuid()) @db.Uuid
  question_id String          @db.Uuid
  text        String
  order       Int
  question    RoadmapQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("roadmap_question_options")
}

model MatchingPair {
  id          String          @id @default(uuid()) @db.Uuid
  question_id String          @db.Uuid
  left        String
  right       String
  order       Int
  question    RoadmapQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("matching_pairs")
}

model ModuleAttempt {
  id         String         @id @default(uuid()) @db.Uuid
  module_id  String         @db.Uuid
  student_id String         @db.Uuid
  score      Int
  total      Int
  passed     Boolean
  created_at DateTime       @default(now())
  module     RoadmapModule  @relation(fields: [module_id], references: [id], onDelete: Cascade)
  student    Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)
  answers    ModuleAnswer[]

  @@unique([module_id, student_id])
  @@map("module_attempts")
}

model ModuleAnswer {
  id          String          @id @default(uuid()) @db.Uuid
  attempt_id  String          @db.Uuid
  question_id String          @db.Uuid
  answer      String
  is_correct  Boolean
  attempt     ModuleAttempt   @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question    RoadmapQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("module_answers")
}

model Post {
  id          String   @id @default(uuid()) @db.Uuid
  school_id   String   @db.Uuid
  author_id   String   @db.Uuid // profile.id
  content     String? // text (nullable if image only)
  image_url   String? // Supabase Storage public URL
  image_path  String? // Supabase Storage path (for deletion)
  reply_to_id String?  @db.Uuid // null = top-level post
  created_at  DateTime @default(now())

  school    School         @relation(fields: [school_id], references: [id], onDelete: Cascade)
  author    Profile        @relation(fields: [author_id], references: [id], onDelete: Cascade)
  reply_to  Post?          @relation("PostReplies", fields: [reply_to_id], references: [id], onDelete: Cascade)
  replies   Post[]         @relation("PostReplies")
  reactions PostReaction[]

  @@map("posts")
}

model PostReaction {
  id        String       @id @default(uuid()) @db.Uuid
  post_id   String       @db.Uuid
  author_id String       @db.Uuid
  type      ReactionType

  post   Post    @relation(fields: [post_id], references: [id], onDelete: Cascade)
  author Profile @relation(fields: [author_id], references: [id], onDelete: Cascade)

  @@unique([post_id, author_id]) // one reaction per user per post
  @@map("post_reactions")
}

enum ReactionType {
  LIKE
  LOVE
  DISLIKE
  HAHA
  SAD
}

// ─────────────────────────────────────────────────────────────
// LESSONS — teacher-authored class lessons with content + Qs
// ─────────────────────────────────────────────────────────────

model Lesson {
  id             String           @id @default(uuid()) @db.Uuid
  teacher_id     String           @db.Uuid
  school_id      String           @db.Uuid
  class_id       String           @db.Uuid
  // Concept (RoadmapModule) the lesson is tied to. Required for NEW lessons.
  // Existing pre-milestone lessons are backfilled to NULL + is_legacy=true.
  module_id      String?          @db.Uuid
  title          String
  description    String?
  // Kept for backwards compat; new visibility is review_status==APPROVED.
  is_published   Boolean          @default(false)
  // Review pipeline
  review_status  ContentReviewStatus @default(DRAFT)
  reviewer_id    String?             @db.Uuid
  reviewer_notes String?
  submitted_at   DateTime?
  reviewed_at    DateTime?
  // Pre-milestone lessons hidden from students; teacher sees as read-only.
  is_legacy      Boolean          @default(false)
  // true  = graded mode (one attempt, score recorded)
  // false = practice mode (instant feedback, retryable, no grade)
  is_graded      Boolean          @default(true)
  linked_quiz_id String?          @db.Uuid
  order          Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  teacher        Teacher          @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  school         School           @relation(fields: [school_id], references: [id], onDelete: Cascade)
  class          Class            @relation(fields: [class_id], references: [id], onDelete: Cascade)
  module         RoadmapModule?   @relation("ModuleLessons", fields: [module_id], references: [id], onDelete: SetNull)
  reviewer       Profile?         @relation("LessonReviewedBy", fields: [reviewer_id], references: [id])
  linked_quiz    Quiz?            @relation(fields: [linked_quiz_id], references: [id], onDelete: SetNull)
  contents       LessonContent[]
  questions      LessonQuestion[]
  attempts       LessonAttempt[]

  @@index([teacher_id])
  @@index([class_id, is_published])
  @@index([module_id, review_status])
  @@index([school_id, review_status])
  @@map("lessons")
}

model LessonContent {
  id           String      @id @default(uuid()) @db.Uuid
  lesson_id    String      @db.Uuid
  type         ContentType
  order        Int
  // TEXT-only fields. Body can include inline markdown-like formatting
  // (**bold**, __highlight__, etc.) rendered by the lesson viewer.
  body         String?
  // IMAGE-only fields
  storage_path String?
  image_url    String?
  alt_text     String?
  // VIDEO-only fields
  video_url    String?
  video_title  String?
  created_at   DateTime    @default(now())

  lesson       Lesson      @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@index([lesson_id, order])
  @@map("lesson_contents")
}

model LessonQuestion {
  id             String                 @id @default(uuid()) @db.Uuid
  lesson_id      String                 @db.Uuid
  type           QuestionType
  text           String
  correct_answer String?
  order          Int
  created_at     DateTime               @default(now())

  lesson         Lesson                 @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  options        LessonQuestionOption[]
  matching_pairs LessonMatchingPair[]
  answers        LessonAnswer[]

  @@index([lesson_id, order])
  @@map("lesson_questions")
}

model LessonQuestionOption {
  id          String         @id @default(uuid()) @db.Uuid
  question_id String         @db.Uuid
  text        String
  order       Int
  question    LessonQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("lesson_question_options")
}

model LessonMatchingPair {
  id          String         @id @default(uuid()) @db.Uuid
  question_id String         @db.Uuid
  left        String
  right       String
  order       Int
  question    LessonQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("lesson_matching_pairs")
}

model LessonAttempt {
  id           String         @id @default(uuid()) @db.Uuid
  lesson_id    String         @db.Uuid
  student_id   String         @db.Uuid
  score        Int?
  total        Int?
  completed_at DateTime?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  lesson       Lesson         @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  student      Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)
  answers      LessonAnswer[]

  @@unique([lesson_id, student_id])
  @@map("lesson_attempts")
}

model LessonAnswer {
  id          String         @id @default(uuid()) @db.Uuid
  attempt_id  String         @db.Uuid
  question_id String         @db.Uuid
  answer      String
  is_correct  Boolean?
  created_at  DateTime       @default(now())

  attempt     LessonAttempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question    LessonQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@map("lesson_answers")
}

enum Role {
  OWNER
  SCHOOL_ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  MCQ
  TF
  WRITTEN
  MATCHING
}

enum ContentType {
  TEXT
  IMAGE
  VIDEO
}

enum StudentOnboardingStatus {
  PENDING_INTAKE
  INTAKE_SUBMITTED
  SCHOOL_ASSIGNED
  SCHOOL_PLACEMENT_SUBMITTED
  CLASS_ASSIGNED
}

enum AssessmentType {
  PLATFORM_INTAKE
  SCHOOL_PLACEMENT
}

enum AssessmentReviewStatus {
  PENDING
  REVIEWED
}
